<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>RAVIYA ACCOUNT STORE</title>

<style>

body{
  margin:0;
  background:#0d0d0d;
  font-family:Arial,sans-serif;
}

.hero{
  position:relative;
  width:100%;
  max-width:1400px;
  margin:auto;
  overflow:hidden;
}

.hero img{
  width:100%;
  height:auto;
  display:block;
}

.hero-content{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  text-align:center;
  color:white;
  width:100%;
}

.hero-content h1{
  font-size:55px;
  margin:0;
  text-shadow:0 0 20px black;
}

.hero-content p{
  font-size:22px;
  letter-spacing:4px;
  margin-top:10px;
  text-shadow:0 0 10px black;
}

.btn{
  display:inline-block;
  margin-top:20px;
  padding:14px 28px;
  border-radius:14px;
  text-decoration:none;
  font-weight:bold;
  font-size:18px;
}

.whatsapp{
  background:#00bfff;
  color:white;
  margin-right:10px;
}

#installBtn{
  background:#00ff99;
  color:black;
  border:none;
  cursor:pointer;
}

</style>
</head>

<body>

<section class="hero">

<img src="banner.png" alt="Banner">

<div class="hero-content">

<h1>RAVIYA ACCOUNT STORE</h1>

<p>BUY • SELL • EXCHANGE</p>

<a href="https://wa.me/94763162805"
class="btn whatsapp">
💬 WhatsApp
</a>

<button class="btn"
id="installBtn">
📲 Install App
</button>

</div>
</section>

<script>

let deferredPrompt;

window.addEventListener(
'beforeinstallprompt',
(e) => {

e.preventDefault();

deferredPrompt = e;

document
.getElementById('installBtn')
.addEventListener('click', () => {

deferredPrompt.prompt();

});

});

</script>

</body>
</html>
